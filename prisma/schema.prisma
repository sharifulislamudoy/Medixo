// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


enum Role {
  ADMIN
  SHOP_OWNER
  DELIVERY_BOY
  SUPPLIER
}

enum UserStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum ProductCategory {
  MEDICINE
  SURGICAL
  OTC
  HERBAL
  DIABETES_CARE
  CARDIAC
  INJECTABLE
  MEDI_DEVICE
  OTHER
}

model User {
  id        String     @id @default(cuid())
  name      String
  email     String     @unique
  phone     String     @unique
  password  String
  address   String
  shopName  String?
  role      Role       @default(SHOP_OWNER)
  status    UserStatus @default(PENDING)
  createdAt DateTime   @default(now())
}

model Advertisement {
  id          String   @id @default(cuid())
  title       String
  imageUrl    String
  category    String   // "ANNOUNCEMENT" | "PRODUCT"
  hyperlink   String?
  isVisible   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PromotionModal {
  id        String   @id @default(cuid())
  title     String
  imageUrl  String
  hyperlink String?
  isVisible Boolean  @default(false) // default false
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Generic {
  id        String   @id @default(cuid())
  name      String   @unique
  products  Product[]
  createdAt DateTime @default(now())
}

model Brand {
  id        String   @id @default(cuid())
  name      String   @unique
  products  Product[]
  createdAt DateTime @default(now())
}

model Product {
  id           String         @id @default(cuid())
  name         String
  category     ProductCategory
  sku          String         @unique
  mrp          Float
  genericId    String?
  generic      Generic?       @relation(fields: [genericId], references: [id])
  brandId      String?
  brand        Brand?         @relation(fields: [brandId], references: [id])
  image        String
  description  String         @db.Text
  sellPrice    Float
  costPrice    Float
  profitMargin Float          // new field: profit margin percentage
  status       Boolean        @default(true)    // true = show in public
  availability Boolean        @default(true)    // true = in stock, false = out of stock
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  stock        Stock?                           // relation to separate stock table
}

model Stock {
  id        String   @id @default(cuid())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String   @unique
  quantity  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}